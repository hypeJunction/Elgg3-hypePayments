{
    "name": "hypejunction/hypepayments",
    "type": "elgg-plugin",
    "description": "Payments API for Elgg",
    "homepage": "https://github.com/hypeJunction/Elgg3-hypePayments",
    "keywords": [
        "elgg",
        "plugin",
        "payments"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "elgg/elgg": "~7.0.0",
        "composer/installers": "^2.0",
        "moneyphp/money": "^4.0"
    },
    "extra": {
        "installer-name": "hypepayments"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "autoload": {
        "psr-4": {
            "hypeJunction\\Payments\\": "classes/hypeJunction/Payments/"
        }
    },
    "version": "3.2.2"
}
