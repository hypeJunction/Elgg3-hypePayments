{
    "name": "hypejunction/hypepayments",
    "type": "elgg-plugin",
    "description": "Payments API for Elgg",
    "homepage": "https://github.com/hypeJunction/hypepayments",
    "keywords": [
        "elgg",
        "plugin",
        "payments"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "hypeJunction",
            "homepage": "https://github.com/hypeJunction"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "elgg/elgg": "~7.0.0",
        "composer/installers": "^2.0",
        "moneyphp/money": "^4.0"
    },
    "extra": {
        "installer-name": "hypePayments"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "autoload": {
        "psr-0": {
            "": "classes/"
        }
    }
}
